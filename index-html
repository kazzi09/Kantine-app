<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kantine App</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
body { font-family: sans-serif; background:#0f172a; color:white; }
.btn { padding:15px; border-radius:10px; width:100%; margin-top:10px; font-weight:bold; display:flex; align-items:center; justify-content:flex-start; gap:10px; }
.primary { background:#6366f1; }
.success { background:#10b981; }
.card { background:white; color:black; padding:15px; border-radius:12px; margin-top:10px; }
.menu-icon { width:24px; height:24px; }
</style>
</head>
<body class="p-5">

<h1 class="text-2xl font-bold mb-4">🍽 Kantine</h1>

<div id="nameScreen">
<input id="nameInput" class="w-full p-3 rounded text-black" placeholder="Uw naam">
<button class="btn primary" onclick="startOrder()">Start</button>
</div>

<div id="menuScreen" style="display:none">
<h2 class="text-xl mb-2">Bestellen</h2>
<div id="menu"></div>
<button class="btn success" onclick="sendOrder()">Verstuur</button>
</div>

<div id="adminScreen" style="display:none">
<h2 class="text-xl mt-5">Admin</h2>
<div id="orders"></div>
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, set, onValue } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

/* FIREBASE */
const firebaseConfig = {
  databaseURL: "https://kantine-app-67c58-default-rtdb.europe-west1.firebasedatabase.app/"
};
const app = initializeApp(firebaseConfig);
const db = getDatabase(app);

/* DATA */
let orders = [];
let currentName = "";
let selectedItems = [];

/* MENU JSON */
const menuItems = [
  { name:"Soep", icon:"🥣" },
  { name:"Salade", icon:"🥗" },
  { name:"Brood", icon:"🍞" },
  { name:"Hamburger", icon:"🍔" },
  { name:"Burek", icon:"🥟" },
  { name:"Chicken Nuggets", icon:"🍗" }
];

const menuDiv = document.getElementById("menu");

/* MENU BUTTONS */
menuItems.forEach(item=>{
  let btn = document.createElement("button");
  btn.className="btn primary";
  btn.innerHTML = `<span class="menu-icon">${item.icon}</span> ${item.name}`;
  btn.onclick = () => toggleItem(item.name);
  menuDiv.appendChild(btn);
});

function toggleItem(item){
  if(selectedItems.includes(item)){
    selectedItems = selectedItems.filter(i => i !== item);
  } else {
    selectedItems.push(item);
  }
}

/* START ORDER */
window.startOrder = function(){
  currentName = document.getElementById("nameInput").value;
  if(currentName.length<2) return alert("Naam invoeren");
  document.getElementById("nameScreen").style.display="none";
  document.getElementById("menuScreen").style.display="block";
};

/* SEND ORDER */
window.sendOrder = async function(){
  if(selectedItems.length === 0) return alert("Kies minstens één item");

  const newOrder = {
    id: Date.now(),
    name: currentName,
    items: selectedItems,
    status: "waiting",
    date: new Date().toLocaleDateString("nl-NL")
  };

  orders.unshift(newOrder);
  await set(ref(db,"orders"),orders);

  alert("Bestelling verstuurd!");
  selectedItems=[];
  document.getElementById("menuScreen").style.display="none";
  document.getElementById("nameScreen").style.display="block";
};

/* REALTIME LISTENER */
onValue(ref(db,"orders"), snapshot=>{
  orders = snapshot.val() || [];
  renderOrders();
});

function renderOrders(){
  const div = document.getElementById("orders");
  div.innerHTML = "";
  orders.forEach(order=>{
    let card = document.createElement("div");
    card.className = "card";
    card.innerHTML = `
      <strong>${order.name}</strong><br>
      ${order.items.join(", ")}<br>
      Status: ${order.status}
    `;
    div.appendChild(card);
  });
}
</script>
</body>
</html>
